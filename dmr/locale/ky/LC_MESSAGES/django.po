#, python-brace-format
msgid ""
"Path {cls} with field_model={field_model} does not allow unnamed path "
"parameters args={args}"
msgstr ""
"{cls} жолу field_model={field_model} менен аталбаган жол параметрлерине "
"уруксат бербейт args={args}"

#, python-brace-format
msgid ""
"Trying to parse files with {parser_name} that does not support "
"SupportsFileParsing protocol"
msgstr ""
"SupportsFileParsing протоколун колдобогон {parser_name} аркылуу файлдарды "
"талдоого аракет жасалууда"

#, python-brace-format
msgid "Method {method} is not allowed, allowed: {allowed}"
msgstr "{method} ыкмасына уруксат жок, уруксат берилгендер: {allowed}"

msgid "Not authenticated"
msgstr "Аутентификациядан өтүлгөн эмес"

msgid "Too many requests"
msgstr "Өтүнүчтөр өтө көп"

msgid "Internal server error"
msgstr "Сервердин ички катасы"

msgid ""
"HTTP requests with the 'application/x-www-form-urlencoded' content type must "
"be UTF-8 encoded."
msgstr ""
"'application/x-www-form-urlencoded' мазмун түрүндөгү HTTP өтүнүчтөрү UTF-8 "
"менен коддолушу керек."

#, python-brace-format
msgid ""
"Negotiated renderer {renderer_type} does not match returned content-type "
"{content_type}"
msgstr ""
"Макулдашылган рендерер {renderer_type} кайтарылган мазмун түрүнө "
"{content_type} дал келбейт"

#, python-brace-format
msgid ""
"Cannot serialize response body with accepted types {accepted_types}, "
"supported={supported}"
msgstr ""
"Жооп денесин {accepted_types} кабыл алынган түрлөрү менен сериялаштыруу "
"мүмкүн эмес, колдоолор={supported}"

#, python-brace-format
msgid ""
"Cannot parse request body with content type {content_type}, "
"expected={expected}"
msgstr ""
"{content_type} мазмун түрү менен өтүнүч денесин талдоо мүмкүн эмес, "
"күтүлгөн={expected}"

#, python-brace-format
msgid "CSRF Failed: {reason}"
msgstr "CSRF катасы: {reason}"

msgid "BlocklistedJWToken"
msgstr "Бөгөттөлгөн JWT токен"

msgid "BlocklistedJWTokens"
msgstr "Бөгөттөлгөн JWT токендер"

#, python-brace-format
msgid "Value {value} of type {type} is not supported for {target_type}"
msgstr "{type} түрүндөгү {value} мааниси {target_type} үчүн колдоолбойт"
