#: dmr/components.py:54
#, python-brace-format
msgid ""
"Path {cls} with field_model={field_model} does not allow unnamed path "
"parameters args={args}"
msgstr ""
"field_model={field_model} bilan {cls} yo'li nomsiz path parametrlari "
"args={args} ga ruxsat bermaydi"

#: dmr/components.py:59
#, python-brace-format
msgid ""
"Trying to parse files with {parser_name} that does not support "
"SupportsFileParsing protocol"
msgstr ""
"SupportsFileParsing protokolini qo'llamaydigan {parser_name} yordamida "
"fayllarni tahlil qilishga urinish"

#: dmr/controller.py:33
#, python-brace-format
msgid "Method {method} is not allowed, allowed: {allowed}"
msgstr "{method} metodiga ruxsat berilmagan, ruxsat etilganlari: {allowed}"

#: dmr/exceptions.py:10
msgid "Not authenticated"
msgstr "Autentifikatsiyadan o'tilmagan"

#: dmr/exceptions.py:11
msgid "Too many requests"
msgstr "So'rovlar soni juda ko'p"

#: dmr/exceptions.py:49
msgid "Internal server error"
msgstr "Serverning ichki xatosi"

#: dmr/internal/django.py:49
msgid ""
"HTTP requests with the 'application/x-www-form-urlencoded' content type must "
"be UTF-8 encoded."
msgstr ""
"'application/x-www-form-urlencoded' content type ga ega HTTP so'rovlari "
"UTF-8 da kodlangan bo'lishi kerak."

#: dmr/internal/negotiation.py:18
#, python-brace-format
msgid ""
"Cannot serialize response body with accepted types {accepted_types}, "
"supported={supported}"
msgstr ""
"Response body ni qabul qilingan {accepted_types} turlari bilan "
"serializatsiya qilib bo'lmaydi, qo'llab-quvvatlanadiganlari: {supported}"

#: dmr/negotiation.py:20
#, python-brace-format
msgid ""
"Cannot parse request body with content type {content_type}, "
"expected={expected}"
msgstr ""
"{content_type} content type li request body ni parse qilib bo'lmaydi, "
"kutilgani: {expected}"

#: dmr/security/django_session/auth.py:22
#, python-brace-format
msgid "CSRF Failed: {reason}"
msgstr "CSRF muvaffaqiyatsiz tugadi: {reason}"

#: dmr/security/jwt/blocklist/models.py:44
msgid "BlocklistedJWToken"
msgstr "Bloklangan JWToken"

#: dmr/security/jwt/blocklist/models.py:45
msgid "BlocklistedJWTokens"
msgstr "Bloklangan JWT tokenlar"

#: dmr/serializer.py:16
#, python-brace-format
msgid "Value {value} of type {type} is not supported for {target_type}"
msgstr "{type} turidagi {value} qiymati {target_type} uchun qo'llab-quvvatlanmaydi"
