#, python-brace-format
msgid ""
"Path {cls} with field_model={field_model} does not allow unnamed path "
"parameters args={args}"
msgstr ""
"field_model={field_model} के साथ Path {cls} बिना नाम वाले path पैरामीटर्स "
"args={args} की अनुमति नहीं देता है"

#, python-brace-format
msgid ""
"Trying to parse files with {parser_name} that does not support "
"SupportsFileParsing protocol"
msgstr ""
"{parser_name} के साथ फाइल पार्स करने का प्रयास किया जा रहा है, जो "
"SupportsFileParsing प्रोटोकॉल को सपोर्ट नहीं करता है"

#, python-brace-format
msgid "Method {method} is not allowed, allowed: {allowed}"
msgstr "मेथड {method} की अनुमति नहीं है, अनुमत मेथड: {allowed}"

msgid "Not authenticated"
msgstr "प्रमाणित नहीं है"

msgid "Too many requests"
msgstr ""

msgid "Internal server error"
msgstr "आंतरिक सर्वर त्रुटि"

msgid ""
"HTTP requests with the 'application/x-www-form-urlencoded' content type must "
"be UTF-8 encoded."
msgstr ""
"'application/x-www-form-urlencoded' कंटेंट टाइप वाले HTTP अनुरोध UTF-8 एन्कोडेड होने "
"चाहिए"

#, python-brace-format
msgid ""
"Negotiated renderer {renderer_type} does not match returned content-type "
"{content_type}"
msgstr ""

#, python-brace-format
msgid ""
"Cannot serialize response body with accepted types {accepted_types}, "
"supported={supported}"
msgstr ""
"स्वीकृत प्रकार {accepted_types} के साथ response body को serialize नहीं किया जा "
"सकता, समर्थित={supported}"

#, python-brace-format
msgid ""
"Cannot parse request body with content type {content_type}, "
"expected={expected}"
msgstr ""
"content type {content_type} के साथ request body को parse नहीं किया जा सकता, "
"अपेक्षित={expected}"

#, python-brace-format
msgid "CSRF Failed: {reason}"
msgstr "CSRF विफल: {reason}"

msgid "BlocklistedJWToken"
msgstr "ब्लॉकलिस्ट किया गया JWT टोकन"

msgid "BlocklistedJWTokens"
msgstr "ब्लॉकलिस्ट किए गए JWT टोकन"

#, python-brace-format
msgid "Value {value} of type {type} is not supported for {target_type}"
msgstr "{type} प्रकार का मान {value}, {target_type} के लिए समर्थित नहीं है"
