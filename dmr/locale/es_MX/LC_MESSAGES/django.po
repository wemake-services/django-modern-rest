#, python-brace-format
msgid ""
"Path {cls} with field_model={field_model} does not allow unnamed path "
"parameters args={args}"
msgstr ""
"La ruta {cls} con field_model={field_model} no permite parámetros de ruta "
"sin nombre args={args}"


#, python-brace-format
msgid ""
"Trying to parse files with {parser_name} that does not support "
"SupportsFileParsing protocol"
msgstr ""
"Se intentó analizar archivos con {parser_name}, que no es compatible con el "
"protocolo SupportsFileParsing"


#, python-brace-format
msgid "Method {method} is not allowed, allowed: {allowed}"
msgstr "El método {method} no está permitido, permitidos: {allowed}"


msgid "Not authenticated"
msgstr "No autenticado"


msgid "Too many requests"
msgstr "Demasiadas solicitudes"


msgid "Internal server error"
msgstr "Error interno del servidor"


msgid ""
"HTTP requests with the 'application/x-www-form-urlencoded' content type must "
"be UTF-8 encoded."
msgstr ""
"Las solicitudes HTTP con el tipo de contenido "
"'application/x-www-form-urlencoded' deben estar codificadas en UTF-8."


#, python-brace-format
msgid ""
"Negotiated renderer {renderer_type} does not match returned content-type "
"{content_type}"
msgstr ""
"El renderer negociado {renderer_type} no coincide con el content-type "
"devuelto {content_type}"


#, python-brace-format
msgid ""
"Cannot serialize response body with accepted types {accepted_types}, "
"supported={supported}"
msgstr ""
"No se puede serializar el cuerpo de la respuesta con los tipos aceptados "
"{accepted_types}, admitidos={supported}"


#, python-brace-format
msgid ""
"Cannot parse request body with content type {content_type}, "
"expected={expected}"
msgstr ""
"No se puede analizar el cuerpo de la solicitud con el content type "
"{content_type}, esperado={expected}"


#, python-brace-format
msgid "CSRF Failed: {reason}"
msgstr "Fallo de CSRF: {reason}"


msgid "BlocklistedJWToken"
msgstr "JWToken en lista de bloqueo"


msgid "BlocklistedJWTokens"
msgstr "JWTokens en lista de bloqueo"


#, python-brace-format
msgid "Value {value} of type {type} is not supported for {target_type}"
msgstr "El valor {value} de tipo {type} no es compatible con {target_type}"
