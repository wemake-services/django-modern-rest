#, python-brace-format
msgid ""
"Path {cls} with field_model={field_model} does not allow unnamed path "
"parameters args={args}"
msgstr ""
"{cls} юлы field_model={field_model} белән исемсез args={args} юл "
"параметрларын тыела"

#, python-brace-format
msgid ""
"Trying to parse files with {parser_name} that does not support "
"SupportsFileParsing protocol"
msgstr ""
"Файлларны SupportsFileParsing беркетмәсен хупламаган {parser_name} белән "
"сүтерергә тырышу"

#, python-brace-format
msgid "Method {method} is not allowed, allowed: {allowed}"
msgstr "Ысул {method} тыелган, рөхсәт ителгәннәр ысуллар: {allowed}"

msgid "Not authenticated"
msgstr "Аутентификация ясылмаган"

msgid "Too many requests"
msgstr ""

msgid "Internal server error"
msgstr "Эчке сервер хатасы"

msgid ""
"HTTP requests with the 'application/x-www-form-urlencoded' content type must "
"be UTF-8 encoded."
msgstr ""
"'application/x-www-form-urlencoded' эчтәлек типы булган HTTP сораулары UTF-8 "
"кодировкасы белән булырга тиеш."

#, python-brace-format
msgid ""
"Negotiated renderer {renderer_type} does not match returned content-type "
"{content_type}"
msgstr ""

#, python-brace-format
msgid ""
"Cannot serialize response body with accepted types {accepted_types}, "
"supported={supported}"
msgstr ""
"Кабул ителгән {accepted_types} типлар белән җавап гәүдәсен сериализацияне "
"ясарга булмый, хуплаган типлар={supported}"

#, python-brace-format
msgid ""
"Cannot parse request body with content type {content_type}, "
"expected={expected}"
msgstr ""
"{content_type} эчтәлек типы белән сорау гәүдәсен сүтеп булмый, көтелгән "
"тип={expected}"

#, python-brace-format
msgid "CSRF Failed: {reason}"
msgstr "CSRF уңышсыз: {reason}"

msgid "BlocklistedJWToken"
msgstr ""

msgid "BlocklistedJWTokens"
msgstr ""

#, python-brace-format
msgid "Value {value} of type {type} is not supported for {target_type}"
msgstr "{target_type} өчен {type} типындагы {value} кыйммәте хупланмый"
