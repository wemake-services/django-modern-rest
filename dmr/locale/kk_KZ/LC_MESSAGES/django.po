#, python-brace-format
msgid ""
"Path {cls} with field_model={field_model} does not allow unnamed path "
"parameters args={args}"
msgstr ""
"{cls} жолы field_model={field_model} параметрімен атаусыз жол параметрлеріне "
"args={args} рұқсат бермейді"

#, python-brace-format
msgid ""
"Trying to parse files with {parser_name} that does not support "
"SupportsFileParsing protocol"
msgstr ""
"SupportsFileParsing протоколын қолдамайтын {parser_name} арқылы файлдарды "
"талдау әрекеті"

#, python-brace-format
msgid "Method {method} is not allowed, allowed: {allowed}"
msgstr "{method} әдісіне рұқсат жоқ, рұқсат етілгендер: {allowed}"

msgid "Not authenticated"
msgstr "Аутентификация жасалмаған"

msgid "Too many requests"
msgstr ""

msgid "Internal server error"
msgstr "Сервердің ішкі қатесі"

msgid ""
"HTTP requests with the 'application/x-www-form-urlencoded' content type must "
"be UTF-8 encoded."
msgstr ""
"'application/x-www-form-urlencoded' мазмұн түріндегі HTTP сұраулары UTF-8 "
"кодтауында болуы тиіс."

#, python-brace-format
msgid ""
"Negotiated renderer {renderer_type} does not match returned content-type "
"{content_type}"
msgstr ""

#, python-brace-format
msgid ""
"Cannot serialize response body with accepted types {accepted_types}, "
"supported={supported}"
msgstr ""
"Жауап денесін қабылданған түрлермен {accepted_types} сериялау мүмкін емес, "
"қолдау көрсетілетіндер={supported}"

#, python-brace-format
msgid ""
"Cannot parse request body with content type {content_type}, "
"expected={expected}"
msgstr ""
"Сұрау денесін {content_type} мазмұн түрімен талдау мүмкін емес, "
"күтілетін={expected}"

#, python-brace-format
msgid "CSRF Failed: {reason}"
msgstr "CSRF тексеруі сәтсіз аяқталды: {reason}"

msgid "BlocklistedJWToken"
msgstr ""

msgid "BlocklistedJWTokens"
msgstr ""

#, python-brace-format
msgid "Value {value} of type {type} is not supported for {target_type}"
msgstr "{type} түріндегі {value} мәні {target_type} үшін қолдау көрсетілмейді"
