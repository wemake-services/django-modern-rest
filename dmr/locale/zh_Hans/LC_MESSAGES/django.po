#, python-brace-format
msgid ""
"Path {cls} with field_model={field_model} does not allow unnamed path "
"parameters args={args}"
msgstr ""
"路径 {cls}（field_model={field_model}）不允许使用未命名的路径参数 args={args}"


#, python-brace-format
msgid ""
"Trying to parse files with {parser_name} that does not support "
"SupportsFileParsing protocol"
msgstr ""
"尝试使用不支持 SupportsFileParsing 协议的 {parser_name} 解析文件"

#, python-brace-format
msgid "Method {method} is not allowed, allowed: {allowed}"
msgstr "不允许使用 {method} 方法，允许的方法：{allowed}"

msgid "Not authenticated"
msgstr "未通过身份验证"

msgid "Too many requests"
msgstr "请求过多"

msgid "Internal server error"
msgstr "服务器内部错误"

msgid ""
"HTTP requests with the 'application/x-www-form-urlencoded' content type must "
"be UTF-8 encoded."
msgstr ""
"内容类型为 'application/x-www-form-urlencoded' 的 HTTP 请求必须使用 UTF-8 编码。"

#, python-brace-format
msgid ""
"Negotiated renderer {renderer_type} does not match returned content-type "
"{content_type}"
msgstr ""
"协商得到的渲染器 {renderer_type} 与返回的内容类型 {content_type} 不匹配"

#, python-brace-format
msgid ""
"Cannot serialize response body with accepted types {accepted_types}, "
"supported={supported}"
msgstr ""
"无法使用可接受类型 {accepted_types} 序列化响应体，支持的类型={supported}"

#, python-brace-format
msgid ""
"Cannot parse request body with content type {content_type}, "
"expected={expected}"
msgstr ""
"无法使用内容类型 {content_type} 解析请求体，期望类型={expected}"

#, python-brace-format
msgid "CSRF Failed: {reason}"
msgstr "CSRF 验证失败：{reason}"

msgid "BlocklistedJWToken"
msgstr "已加入黑名单的 JWT 令牌"

msgid "BlocklistedJWTokens"
msgstr "已加入黑名单的 JWT 令牌"

#, python-brace-format
msgid "Value {value} of type {type} is not supported for {target_type}"
msgstr "类型为 {type} 的值 {value} 不支持用于 {target_type}"
